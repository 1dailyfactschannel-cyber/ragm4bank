# Это ШАБЛОН для репозитория (без секретов)
# При деплое в Portainer скопируйте значения из файла portainer-env.txt
# Или вставьте вручную из защищенного хранилища

BOT_TOKEN=your-telegram-bot-token-from-botfather
JWT_SECRET=change-this-to-32-char-random-string
POSTGRES_PASSWORD=strong-postgres-password
ADMIN_CHAT_IDS=
CORS_ORIGINS=*
LOG_LEVEL=INFO
